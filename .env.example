# ============================================
# BIG MAN BARBER SHOP — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha com
# suas credenciais reais.

# -----------------------------------------------
# WhatsApp Cloud API (Meta Developer)
# -----------------------------------------------

# Token de acesso permanente gerado no Meta Developer
WHATSAPP_ACCESS_TOKEN=seu_token_aqui

# ID do número de telefone do WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id_aqui

# Token de verificação que você cria (qualquer string)
WHATSAPP_VERIFY_TOKEN=bigman_verify_2024

# Número de WhatsApp para receber relatórios (ex: 5511999999999)
REPORT_PHONE_NUMBER=5511999999999

# -----------------------------------------------
# Google Gemini API
# -----------------------------------------------

# Chave da API do Google AI Studio (makersuite.google.com)
GEMINI_API_KEY=sua_gemini_api_key_aqui

# -----------------------------------------------
# Supabase
# -----------------------------------------------

# URL do projeto Supabase (ex: https://xxx.supabase.co)
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anon/pública do Supabase
SUPABASE_ANON_KEY=sua_supabase_anon_key_aqui

# -----------------------------------------------
# Servidor
# -----------------------------------------------

PORT=3000
NODE_ENV=development
